# Port the server listens on (hosts usually set this automatically).
PORT=4000

# Set to "production" in production for secure defaults.
NODE_ENV=production

# Comma-separated list of allowed origins for CORS.
# Leave empty to allow same-origin / all (fine for a full-stack single-service deploy).
# Example for a separately-hosted frontend:
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=

# Optional: forward contact-form submissions to a webhook
# (Slack / Discord / Zapier / Make / Formspree, etc.).
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
CONTACT_WEBHOOK_URL=
