# Web3Forms access key for the contact form (get it free at https://web3forms.com).
# Submitted directly from the browser, so this is baked into the build — that's
# expected for Web3Forms (protect it by setting Allowed Domains in their dashboard).
# Set the same var in Vercel → Settings → Environment Variables, then redeploy.
VITE_WEB3FORMS_KEY=

# Only needed if the API is hosted separately from the frontend (not on Vercel).
VITE_API_URL=
